# مثال على الـ .env - انسخ هذا الملف إلى .env وعبئه بقيمك الحقيقية
# لا تفضح الـ secrets الحقيقية على GitHub!

# Telegram Bot Token
# احصل عليه من: https://t.me/botfather
BOT_TOKEN=your_telegram_bot_token_here

# Groq API Key (مهم: لا تشاركه مع أحد!)
# احصل عليه من: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Render Webhook URL (عنوان السيرفر على Render)
WEBHOOK_URL=https://your-render-app.onrender.com

# Server Port (المنفذ)
PORT=3000

# Environment (development أو production)
NODE_ENV=development
